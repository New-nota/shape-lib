{
    "compilerOptions": {
        "target": "es2025",
        "module": "nodenext",
        "lib": ["es2022", "dom"],
        "outDir": "./dist",
        "rootDir": "./src",
        "declaration": true,
        "allowJs": false,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*"]
}